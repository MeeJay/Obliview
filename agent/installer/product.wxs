<?xml version="1.0" encoding="utf-8"?>
<!--
  Obliview Agent - Windows MSI Installer
  Built with WiX v4+ on Windows.

  Prerequisites (one-time setup):
    dotnet tool install -g wix
    go install (Go 1.22+, https://go.dev/dl)

  Build (from agent/ directory):
    build-msi.bat

  Install command:
    msiexec /i obliview-agent.msi SERVERURL="https://..." APIKEY="your-key" /quiet
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Obliview Agent"
           Manufacturer="Obliview"
           Version="AGENT_VERSION_PLACEHOLDER"
           Language="1033"
           UpgradeCode="3A7B2C1D-4E5F-6789-ABCD-EF0123456789">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Obliview Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Properties passed via: msiexec /i ... SERVERURL="..." APIKEY="..." -->
    <Property Id="SERVERURL" Secure="yes" />
    <Property Id="APIKEY" Secure="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="ObliviewAgent">

        <!--
          The Go binary is a proper Windows service executable.
          It calls SetServiceStatus(SERVICE_RUNNING) via golang.org/x/sys/windows/svc,
          so the MSI Wait="yes" (default) resolves normally without hanging.
          The url and key flags are passed as service arguments; on first run the
          agent writes config.json and from then on reads that file directly.
        -->
        <Component Id="AgentExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234560001">
          <!--
            DefaultVersion forces MSI to always overwrite the exe even when the binary on disk
            has no Win32 version resource (Go binaries are unversioned by default).
            Without this, MSI may skip the copy if it finds an "unversioned but modified" file
            on disk (e.g. leftover from a failed previous install), leaving the wrong binary in place.
            65535.0.0.0 is always greater than any real version, so the source file always wins.
          -->
          <File Id="AgentExeFile" Source="dist\obliview-agent.exe" Name="obliview-agent.exe"
                DefaultVersion="65535.0.0.0" />
          <ServiceInstall Id="AgentSvc"
                          Name="ObliviewAgent"
                          DisplayName="Obliview Monitoring Agent"
                          Description="Sends system metrics to the Obliview monitoring platform."
                          Start="auto"
                          Type="ownProcess"
                          Account="LocalSystem"
                          ErrorControl="normal"
                          Arguments='--url "[SERVERURL]" --key "[APIKEY]"' />
          <ServiceControl Id="AgentSvcStart" Name="ObliviewAgent" Start="install" />
          <ServiceControl Id="AgentSvcStop"  Name="ObliviewAgent" Stop="both" Remove="uninstall" Wait="yes" />
        </Component>

        <!--
          NOTE: PawnIO kernel driver was previously bundled here under the
          (mistaken) belief that LibreHardwareMonitorLib required it. It does
          NOT — LHM ships and loads its own WinRing0 driver embedded inside
          LibreHardwareMonitorLib.dll at runtime. PawnIO was installed as a
          parallel kernel driver doing nothing for our pipeline, and turned
          out to be the source of fleet-wide BSODs (confirmed via WinDbg
          !analyze -v on MEMORY.DMP pointing PawnIO.sys). Removed in 1.6.8.
          The Uninstall-Obliview-PawnIO.ps1 mitigation script in this folder
          handles cleanup on hosts that already have PawnIO installed from a
          previous version.
        -->

        <!--
          Registry fallback: agent reads these on first run if config.json is absent
          and the service arguments are not yet parsed (edge cases).
          Written to 64-bit hive via -arch x64 build flag.
        -->
        <Component Id="AgentConfig" Guid="B2C3D4E5-F6A7-8901-BCDE-EF1234560002">
          <RegistryValue Root="HKLM" Key="SOFTWARE\ObliviewAgent"
                         Name="ServerUrl" Type="string" Value="[SERVERURL]" KeyPath="yes" />
          <RegistryValue Root="HKLM" Key="SOFTWARE\ObliviewAgent"
                         Name="ApiKey"    Type="string" Value="[APIKEY]" />
        </Component>

      </Directory>
    </StandardDirectory>

    <Feature Id="Main">
      <ComponentRef Id="AgentExe" />
      <ComponentRef Id="AgentConfig" />
    </Feature>

  </Package>
</Wix>
